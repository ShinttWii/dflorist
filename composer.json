{
    "name": "dflorist/ecommerce",
    "description": "Sistem E-Commerce Toko Bunga dengan Pre-Order dan Pengiriman Terjadwal",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "ext-gd": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "DFlorist\\": "src/"
        },
        "files": [
            "includes/functions.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}

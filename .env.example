# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=dflorist

# Application Configuration
SITE_URL=http://localhost/dflorist
ADMIN_URL=http://localhost/dflorist/admin

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=dfloristreal@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM_EMAIL=dfloristreal@gmail.com
SMTP_FROM_NAME=D'Florist

# Payment Gateway (Midtrans Example)
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=false

# Security
SESSION_LIFETIME=7200
CSRF_TOKEN_NAME=dflorist_csrf_token

# Upload Settings
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif

# Store Settings (Default)
STORE_LATITUDE=-6.200000
STORE_LONGITUDE=106.816666
MAX_DELIVERY_RADIUS=10
MIN_PREORDER_DAYS=2
MAX_QUOTA_PER_DATE=5
